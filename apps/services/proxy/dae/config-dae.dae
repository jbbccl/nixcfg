# dae config — based on official best practice
# https://github.com/daeuniverse/dae/blob/main/example.dae

global {
  tproxy_port: 7897
  wan_interface: auto
  log_level: info
  disable_waiting_network: false
  auto_config_kernel_parameter: true
  allow_insecure: false

  # 节点连通性检查
  tcp_check_url: 'http://cp.cloudflare.com,1.1.1.1,2606:4700:4700::1111'
  tcp_check_http_method: HEAD
  udp_check_dns: 'dns.google:53,8.8.8.8,2001:4860:4860::8888'
  check_interval: 30s
  check_tolerance: 50ms

  # domain 模式 → 远端 DNS 解析，更好避开 DNS 污染
  dial_mode: domain
  sniffing_timeout: 30ms
  tls_implementation: tls

  # 带宽声明 (hysteria2 等协议需要)
  bandwidth_max_tx: '200 mbps'
  bandwidth_max_rx: '1 gbps'
}

# ── 订阅 (机场 URL via SOPS) ────────────────────────────
subscription {
  airport01: 'AIRPORT01_URL_PLACEHOLDER'
  airport02: 'AIRPORT02_URL_PLACEHOLDER'
  airport03: 'AIRPORT03_URL_PLACEHOLDER'
  airport04: 'AIRPORT04_URL_PLACEHOLDER'
}

# ── DNS ──────────────────────────────────────────────────
dns {
  upstream {
    alidns: 'udp://dns.alidns.com:53'
    googledns: 'tcp+udp://dns.google:53'
  }
  routing {
    request {
      qname(geosite:cn) -> alidns
      fallback: googledns
    }
  }
}

# ── 节点分组 ─────────────────────────────────────────────
group {
  proxy {
    filter: subtag(airport01, airport02, airport03, airport04)
    policy: min_moving_avg
  }
}

# ── 路由 ─────────────────────────────────────────────────
routing {
  # 系统网络管理器直连
  pname(NetworkManager) -> direct

  # 组播/广播直连
  dip(224.0.0.0/3, 'ff00::/8') -> direct

  # 禁用 QUIC/h3 (省 CPU/内存)
  l4proto(udp) && dport(443) -> block

  # 私有 IP 直连
  dip(geoip:private) -> direct

  # 国内直连
  dip(geoip:cn) -> direct
  domain(geosite:cn, geosite:private) -> direct

  # 境外代理
  domain(geosite:geolocation-!cn) -> proxy
  domain(geosite:gfw) -> proxy

  fallback: proxy
}
