{
    "label" : "suspend",
    "action" : "swaylock -f & sleep 0.3 && systemctl suspend",
    "text" : " Suspend ",
    "keybind" : "s"
}

{
    "label" : "shutdown",
    "action" : "shutdown -h now",
    "text" : "Shutdown ",
    "keybind" : "d"
}

{
    "label" : "logout",
    "action" : "uwsm stop",
    "text" : " Logout  ",
    "keybind" : "m"
}

{
    "label" : "reboot",
    "action" : "reboot",
    "text" : " Reboot  ",
    "keybind" : "r"
}

{
    "label" : "lock",
    "action" : "swaylock",
    "text" : "  Lock",
    "keybind" : "l"
}

{
    "label" : "hibernate",
    "action" : "systemctl hibernate",
    "text" : "Hibernate",
    "keybind" : "h"
}